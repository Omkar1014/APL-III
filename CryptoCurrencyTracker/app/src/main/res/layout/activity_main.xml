<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA"
    android:padding="12dp"
    tools:context=".MainActivity">

    <!-- Horizontal layout: EditText + Spinner -->
    <LinearLayout
        android:id="@+id/searchLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_alignParentTop="true"
        android:layout_marginBottom="12dp"
        android:padding="6dp"
        android:background="@drawable/search_bg"
        android:elevation="4dp"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/idEdtSearch"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Search Cryptocurrency"
            android:padding="12dp"
            android:background="@android:color/transparent"
            android:textColor="#000000"
            android:textColorHint="#999999"
            android:textSize="16sp" />

        <Spinner
            android:id="@+id/idCurrencySpinner"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="@android:drawable/btn_dropdown"
            android:padding="8dp" />
    </LinearLayout>

    <!-- RecyclerView below the search/spinner layout -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/idRVcurrency"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/searchLayout"
        android:clipToPadding="false"
        android:paddingBottom="60dp" />

    <!-- Centered ProgressBar -->
    <ProgressBar
        android:id="@+id/idPBLoading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:visibility="gone" />

</RelativeLayout>
