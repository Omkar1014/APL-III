<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Name, Symbol, Price Block -->
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_rounded"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/idTVCurrencyName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Currency Name"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="22sp"
                android:paddingBottom="8dp" />

            <TextView
                android:id="@+id/idTVSymbol"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Symbol"
                android:textColor="#B0BEC5"
                android:textSize="18sp"
                android:paddingBottom="8dp" />

            <TextView
                android:id="@+id/idTVCurrencyRate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Price"
                android:textColor="#4CAF50"
                android:textSize="18sp" />
        </LinearLayout>

        <!-- Percent Change Cards -->
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <!-- Change 1h -->
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_rounded"
                android:padding="12dp"
                android:layout_marginBottom="8dp"
                android:gravity="center_vertical">

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_schedule"
                    app:tint="#80CBC4"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:id="@+id/idTVChange1h"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Change 1h"
                    android:textColor="#ECEFF1"
                    android:textSize="16sp" />
            </LinearLayout>

            <!-- Change 24h -->
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_rounded"
                android:padding="12dp"
                android:layout_marginBottom="8dp"
                android:gravity="center_vertical">

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_calendar_today"
                    app:tint="#F48FB1"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:id="@+id/idTVChange24h"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Change 24h"
                    android:textColor="#ECEFF1"
                    android:textSize="16sp" />
            </LinearLayout>

            <!-- Change 7d -->
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_rounded"
                android:padding="12dp"
                android:layout_marginBottom="8dp"
                android:gravity="center_vertical">

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_date_range"
                    app:tint="#CE93D8"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:id="@+id/idTVChange7d"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Change 7 Days"
                    android:textColor="#ECEFF1"
                    android:textSize="16sp" />
            </LinearLayout>

            <!-- Change 30d -->
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_rounded"
                android:padding="12dp"
                android:gravity="center_vertical">

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_trending_up"
                    app:tint="#81D4FA"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:id="@+id/idTVChange30d"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Change 30 Days"
                    android:textColor="#ECEFF1"
                    android:textSize="16sp" />
            </LinearLayout>

        </LinearLayout>

        <!-- Chart -->
        <com.github.mikephil.charting.charts.LineChart
            android:id="@+id/idLineChart"
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:layout_marginTop="16dp" />

    </LinearLayout>
</ScrollView>
